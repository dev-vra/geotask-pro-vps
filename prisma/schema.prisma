generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ActivityLog {
  id         Int      @id @default(autoincrement())
  user_id    Int?
  user_name  String
  action     String
  entity     String?
  entity_id  Int?
  details    String?
  ip_address String?
  created_at DateTime @default(now())
  User       User?    @relation(fields: [user_id], references: [id])

  @@index([action])
  @@index([created_at])
  @@index([user_id])
}

model City {
  id            Int            @id @default(autoincrement())
  name          String         @unique
  neighborhoods Neighborhood[]
  tasks         Task[]
}

model Comment {
  id           Int            @id @default(autoincrement())
  content      String
  created_at   DateTime       @default(now())
  task_id      Int
  user_id      Int?
  Task         Task           @relation(fields: [task_id], references: [id], onDelete: Cascade)
  user         User?          @relation(fields: [user_id], references: [id])
  mentions     Mention[]
  Notification Notification[]

  @@index([task_id])
}

model Contract {
  id            Int            @id @default(autoincrement())
  name          String         @unique
  neighborhoods Neighborhood[]
  tasks         Task[]
}

model Mention {
  id                                   Int      @id @default(autoincrement())
  mention_type                         String
  created_at                           DateTime @default(now())
  comment_id                           Int
  task_id                              Int
  mentioned_user_id                    Int?
  mentioned_by_id                      Int?
  mentioned_sector_id                  Int?
  Comment                              Comment  @relation(fields: [comment_id], references: [id], onDelete: Cascade)
  mentioned_by                         User?    @relation("Mention_mentioned_by_idToUser", fields: [mentioned_by_id], references: [id])
  Sector                               Sector?  @relation(fields: [mentioned_sector_id], references: [id])
  mentioned_user                       User?    @relation("Mention_mentioned_user_idToUser", fields: [mentioned_user_id], references: [id])
  Task                                 Task     @relation(fields: [task_id], references: [id], onDelete: Cascade)
}

model Neighborhood {
  id          Int       @id @default(autoincrement())
  name        String
  city_id     Int
  contract_id Int?
  city        City      @relation(fields: [city_id], references: [id], onDelete: Cascade)
  contract    Contract? @relation(fields: [contract_id], references: [id])
  tasks       Task[]

  @@unique([city_id, name])
}

model Notification {
  id         Int      @id @default(autoincrement())
  type       String
  title      String
  message    String?
  read       Boolean  @default(false)
  created_at DateTime @default(now())
  user_id    Int
  task_id    Int?
  comment_id Int?
  comment    Comment? @relation(fields: [comment_id], references: [id])
  task       Task?    @relation(fields: [task_id], references: [id])
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([task_id])
  @@index([user_id, read])
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  permissions Json?
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now())
  users       User[]
}

model Sector {
  id              Int               @id @default(autoincrement())
  name            String            @unique
  created_at      DateTime          @default(now())
  updated_at      DateTime          @default(now())
  mentions        Mention[]
  subtasks        Subtask[]
  tasks           Task[]
  taskTypes       TaskType[]
  templates       Template[]
  templateSubtasks TemplateSubtask[]
  users           User[]
  userSectors     UserSector[]
}

model Subtask {
  id             Int       @id @default(autoincrement())
  title          String
  done           Boolean   @default(false)
  task_id        Int
  responsible_id Int?
  done_at        DateTime?
  sector_id      Int?
  responsible    User?     @relation(fields: [responsible_id], references: [id])
  Sector         Sector?   @relation(fields: [sector_id], references: [id])
  task           Task      @relation(fields: [task_id], references: [id], onDelete: Cascade)
}

model Task {
  id                             Int              @id @default(autoincrement())
  title                          String
  description                    String?
  type                           String?
  status                         String           @default("A Fazer")
  priority                       String?
  responsible_id                 Int?
  contract_id                    Int?
  city_id                        Int?
  neighborhood_id                Int?
  nucleus                        String?
  quadra                         String?
  lote                           String?
  deadline                       DateTime?
  link                           String?
  created_by_id                  Int?
  created_at                     DateTime         @default(now())
  updated_at                     DateTime?
  started_at                     DateTime?
  paused_at                      DateTime?
  completed_at                   DateTime?
  time_spent                     Int              @default(0)
  parent_id                      Int?
  sector_id                      Int?
  team_id                        Int?
  status_updated_at              DateTime?
  is_recurring                   Boolean          @default(false)
  recurrence_config              Json?
  next_recurrence_at             DateTime?
  last_recurrence_at             DateTime?
  comments                       Comment[]
  mentions                       Mention[]
  notifications                  Notification[]
  subtasks                       Subtask[]
  city                           City?            @relation(fields: [city_id], references: [id])
  contract                       Contract?        @relation(fields: [contract_id], references: [id])
  created_by                     User?            @relation("Task_created_by_idToUser", fields: [created_by_id], references: [id])
  neighborhood                   Neighborhood?    @relation(fields: [neighborhood_id], references: [id])
  parent                         Task?            @relation("TaskToTask", fields: [parent_id], references: [id])
  children                       Task[]           @relation("TaskToTask")
  responsible                    User?            @relation("Task_responsible_idToUser", fields: [responsible_id], references: [id])
  Sector                         Sector?          @relation(fields: [sector_id], references: [id])
  team                           Team?            @relation(fields: [team_id], references: [id])
  attachments                    TaskAttachment[]
  history                        TaskHistory[]
  pauses                         TaskPause[]
  coworkers                      TaskUser[]

  @@index([created_by_id])
  @@index([parent_id])
  @@index([responsible_id])
  @@index([sector_id])
  @@index([status])
  @@index([team_id])
}

model TaskAttachment {
  id             Int      @id @default(autoincrement())
  task_id        Int
  filename       String
  original_name  String
  mime_type      String
  size           Int
  url            String
  uploaded_by_id Int?
  created_at     DateTime @default(now())
  task           Task     @relation(fields: [task_id], references: [id], onDelete: Cascade)
  uploaded_by    User?    @relation(fields: [uploaded_by_id], references: [id])

  @@index([task_id])
}

model TaskHistory {
  id         Int      @id @default(autoincrement())
  task_id    Int
  user_id    Int?
  field      String
  old_value  String?
  new_value  String?
  created_at DateTime @default(now())
  task       Task     @relation(fields: [task_id], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [user_id], references: [id])

  @@index([task_id])
}

model TaskPause {
  id         Int       @id @default(autoincrement())
  task_id    Int
  started_at DateTime  @default(now())
  ended_at   DateTime?
  task       Task      @relation(fields: [task_id], references: [id], onDelete: Cascade)
}

model TaskType {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  sector_id  Int?
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
  Sector     Sector?  @relation(fields: [sector_id], references: [id])

  @@index([sector_id])
}

model TaskUser {
  id         Int      @id @default(autoincrement())
  task_id    Int
  user_id    Int
  created_at DateTime @default(now())
  task       Task     @relation(fields: [task_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([task_id, user_id])
  @@index([task_id])
  @@index([user_id])
}

model Team {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
  tasks      Task[]
  users      User[]
}

model Template {
  id            Int            @id @default(autoincrement())
  name          String
  created_by_id Int?
  created_at    DateTime       @default(now())
  sector_id     Int
  user           User?          @relation(fields: [created_by_id], references: [id])
  Sector         Sector         @relation(fields: [sector_id], references: [id])
  tasks          TemplateTask[]
}

model TemplateSubtask {
  id               Int          @id @default(autoincrement())
  title            String
  order_index      Int          @default(0)
  template_task_id Int
  responsible_id   Int?
  sector_id        Int?
  responsible          User?        @relation(fields: [responsible_id], references: [id])
  Sector               Sector?      @relation(fields: [sector_id], references: [id])
  templateTask     TemplateTask @relation(fields: [template_task_id], references: [id], onDelete: Cascade)
}

model TemplateTask {
  id              Int               @id @default(autoincrement())
  title           String
  order_index     Int               @default(0)
  template_id     Int
  subtasks         TemplateSubtask[]
  template         Template          @relation(fields: [template_id], references: [id], onDelete: Cascade)
}

model User {
  id                                      Int               @id @default(autoincrement())
  name                                    String
  email                                   String            @unique
  password_hash                           String            @default("mock")
  avatar                                  String?
  created_at                              DateTime          @default(now())
  active                                  Boolean           @default(true)
  must_change_password                    Boolean           @default(true)
  role_id                                 Int
  sector_id                               Int
  team_id                                 Int?
  activityLogs                            ActivityLog[]
  comments                                Comment[]
  mentionsSent                            Mention[]         @relation("Mention_mentioned_by_idToUser")
  mentionsReceived                        Mention[]         @relation("Mention_mentioned_user_idToUser")
  notifications                           Notification[]
  subtasks                                Subtask[]
  tasksCreated                            Task[]            @relation("Task_created_by_idToUser")
  tasksResponsible                        Task[]            @relation("Task_responsible_idToUser")
  attachments                             TaskAttachment[]
  history                                 TaskHistory[]
  taskUsers                               TaskUser[]
  templates                               Template[]
  templateSubtasks                        TemplateSubtask[]
  Role                                    Role              @relation(fields: [role_id], references: [id])
  Sector                                  Sector            @relation(fields: [sector_id], references: [id])
  Team                                    Team?             @relation(fields: [team_id], references: [id])
  user_sectors                            UserSector[]

  manager_id                              Int?
  manager                                 User?             @relation("UserSubordinates", fields: [manager_id], references: [id])
  subordinates                            User[]            @relation("UserSubordinates")
  gamings                                 Gaming[]          @relation("GamingUser")
  gamings_evaluated                       Gaming[]          @relation("GamingEvaluator")
  gaming_histories                        GamingHistory[]

  @@index([team_id])
  @@index([manager_id])
}

model UserSector {
  id         Int      @id @default(autoincrement())
  user_id    Int
  sector_id  Int
  created_at DateTime @default(now())
  sector     Sector   @relation(fields: [sector_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, sector_id])
  @@index([sector_id])
  @@index([user_id])
}

model Gaming {
  id             Int              @id @default(autoincrement())
  user_id        Int
  evaluator_id   Int?             
  cycle_type     String           // "Mensal", "Trimestral", etc
  cycle_name     String           // Identificador do marco temporal (ex: Jan-2026)
  status         String           @default("DRAFT") // DRAFT, CLOSED
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt
  closed_at      DateTime?

  user           User             @relation("GamingUser", fields: [user_id], references: [id], onDelete: Cascade)
  evaluator      User?            @relation("GamingEvaluator", fields: [evaluator_id], references: [id], onDelete: SetNull)
  items          GamingItem[]
  history        GamingHistory[]
  snapshots      GamingSnapshot[] 

  @@index([user_id])
  @@index([evaluator_id])
  @@index([status])
}

model GamingItem {
  id             Int       @id @default(autoincrement())
  gaming_id      Int
  description    String
  weight         Float     
  target         Float     
  achieved       Float?    

  gaming         Gaming    @relation(fields: [gaming_id], references: [id], onDelete: Cascade)

  @@index([gaming_id])
}

model GamingHistory {
  id             Int       @id @default(autoincrement())
  gaming_id      Int
  user_id        Int?      
  action         String    
  details        Json?     
  created_at     DateTime  @default(now())

  gaming         Gaming    @relation(fields: [gaming_id], references: [id], onDelete: Cascade)
  user           User?     @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([gaming_id])
}

model GamingSnapshot {
  id             Int       @id @default(autoincrement())
  gaming_id      Int
  file_url       String    
  file_type      String    
  created_at     DateTime  @default(now())

  gaming         Gaming    @relation(fields: [gaming_id], references: [id], onDelete: Cascade)

  @@index([gaming_id])
}
